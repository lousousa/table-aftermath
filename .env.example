# Valid values: production, dev
APP_MODE=dev

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
OPENAI_API_KEY=
OPENAI_RECEIPT_MODEL=gpt-4o-mini

# Used only when APP_MODE=dev.
# Valid values: matching-total, mismatched-total, not-detected
# You can also add a custom mocks/receipt-extraction/<variant>.json file
# and use its filename without the .json extension.
RECEIPT_EXTRACTION_MOCK_VARIANT=matching-total
